# =============================================================================
# IaCraft Configuration — All values are optional, defaults shown
# =============================================================================

# --- Application ---
# APP_NAME=IaCraft
# APP_VERSION=3.0.0
# DASHBOARD_PORT=15000
# DASHBOARD_HOST=0.0.0.0
# OUTPUT_DIR=output

# --- Authentication ---
ADMIN_PASSWORD=your-secure-password
# GUEST_PASSWORD=guest
# SESSION_MAX_AGE_DAYS=30

# --- CORS (comma-separated origins) ---
# CORS_ORIGINS=http://localhost:3000,http://localhost:15000

# =============================================================================
# LLM Provider API Keys (set the ones you want to use)
# =============================================================================

# Option 1: Groq (FREE, fastest — recommended)
GROQ_API_KEY=gsk_your-key-here

# Option 2: Google Gemini (FREE)
# GEMINI_API_KEY=AIza...

# Option 3: Together AI ($25 free credit)
# TOGETHER_API_KEY=...

# Option 4: Mistral AI (free tier)
# MISTRAL_API_KEY=...

# Option 5: DeepSeek (~$0.001/run)
# DEEPSEEK_API_KEY=...

# Option 6: Cohere (free trial)
# COHERE_API_KEY=...

# Option 7: OpenAI (~$0.03/run)
# OPENAI_API_KEY=sk-...

# Option 8: Anthropic Claude (~$0.15/run)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 9: Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=...

# Option 10: AWS Bedrock (uses aws configure)
# AWS_REGION=us-east-1

# Option 11: Ollama (local/remote, free)
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Default Provider & Model (override per-provider defaults)
# =============================================================================
# DEFAULT_PROVIDER=groq
# DEFAULT_MODEL_GROQ=llama-3.3-70b-versatile
# DEFAULT_MODEL_GEMINI=gemini-2.0-flash
# DEFAULT_MODEL_OPENAI=gpt-4o-mini
# DEFAULT_MODEL_CLAUDE=claude-sonnet-4-6-20250514
# DEFAULT_MODEL_OLLAMA=qwen2.5-coder:7b

# =============================================================================
# Cloud Defaults
# =============================================================================
# DEFAULT_REGION_AWS=ap-south-1
# DEFAULT_REGION_AZURE=centralindia
# DEFAULT_REGION_GCP=asia-south1
# DEFAULT_COMPLIANCE=SOC2,ISO27001,CIS

# =============================================================================
# LLM Tuning
# =============================================================================
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=8192
# LLM_MAX_TOKENS_ANALYSIS=4096
# DEFAULT_CONTEXT_SIZE=4096

# =============================================================================
# Ollama Timeouts (seconds)
# =============================================================================
# OLLAMA_CONNECT_TIMEOUT=10
# OLLAMA_READ_TIMEOUT=1800
# OLLAMA_HEALTH_TIMEOUT=5

# =============================================================================
# Validator Settings
# =============================================================================
# VALIDATOR_MAX_ROUNDS=5
# TERRAFORM_CMD_TIMEOUT=120
# CHECKOV_CMD_TIMEOUT=120

# =============================================================================
# Documentation Levels (max tokens per section)
# =============================================================================
# DOC_MAX_TOKENS_QUICK=1024
# DOC_MAX_TOKENS_STANDARD=2048
# DOC_MAX_TOKENS_ENTERPRISE=3072
# DOC_MAX_TOKENS_COMPLIANCE=3072
